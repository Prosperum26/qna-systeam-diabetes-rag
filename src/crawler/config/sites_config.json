{
  "sites": {
    "yhoccongdong": {
      "base_url": "https://yhoccongdong.com/tieu-duong/",
      "default_category": "general",
      "selectors": {
        "article_links": [
          "a.col-12.post-item_content-title",
          "div.post-item_content a",
          ".post-item a"
        ],
        "category_patterns": {
          "dau-hieu": "symptoms",
          "song-chung": "lifestyle",
          "trieu-chung": "symptoms"
        }
      },
      "pagination": {
        "type": "ajax",
        "ajax": {
          "ajax_url": "https://yhoccongdong.com/tieu-duong/wp-admin/admin-ajax.php",
          "action": "watch_more_ar",
          "view": "cancer-default",
          "nonce_param": "_ajax_nonce",
          "initial_page": 1,
          "button_selector": "button.btn.button-post-more",
          "loading_selector": ".ajax-loading",
          "headers": {
            "X-Requested-With": "XMLHttpRequest",
            "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
            "Accept": "*/*",
            "Accept-Encoding": "gzip, deflate, br, zstd",
            "Accept-Language": "vi-VN,vi;q=0.9,fr-FR;q=0.8,fr;q=0.7,en-US;q=0.6,en;q=0.5",
            "Origin": "https://yhoccongdong.com",
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36",
            "sec-ch-ua": "\"Not:A-Brand\";v=\"99\", \"Google Chrome\";v=\"145\", \"Chromium\";v=\"145\"",
            "sec-ch-ua-mobile": "?0",
            "sec-ch-ua-platform": "\"Windows\"",
            "sec-fetch-dest": "empty",
            "sec-fetch-mode": "cors",
            "sec-fetch-site": "same-origin"
          },
          "nonce_patterns": [
            "_ajax_nonce\"\\s*:\\s*\"([a-f0-9]+)\"",
            "_ajax_nonce\"\\s*=\\s*\"([a-f0-9]+)\"",
            "nonce\"\\s*:\\s*\"([a-f0-9]+)\"",
            "nonce_ajax\"\\s*=\\s*{[^}]*_ajax_nonce\"\\s*:\\s*\"([a-f0-9]+)\""
          ]
        }
      }
    },
    "who": {
      "base_url": "https://www.who.int",
      "default_category": "concepts",
      "selectors": {
        "article_links": [
          "a.sf-list-vertical__item",
          "a[href*='/news-room/fact-sheets/detail']",
          "a[href*='/health-topics']"
        ],
        "category_patterns": {
          "fact-sheets": "concepts",
          "health-topics": "general",
          "news-room": "general"
        }
      },
      "pagination": {
        "type": "traditional"
      }
    },
    "niddk": {
      "base_url": "https://www.niddk.nih.gov/health-information/diabetes",
      "default_category": "general",
      "selectors": {
        "article_links": [
          "a[href]"
        ],
        "category_patterns": {
          "prevention": "prevention",
          "treatment": "treatment", 
          "symptoms": "symptoms",
          "causes": "causes",
          "management": "lifestyle"
        }
      },
      "pagination": {
        "type": "traditional"
      }
    },
    "diabetes_org": {
      "base_url": "https://diabetes.org/",
      "default_category": "general",
      "selectors": {
        "article_links": [
          "a[href*='/research/']",
          "a[href*='/living-with-diabetes/']",
          "a[href*='/diabetes-basics/']",
          "a.card__link"
        ],
        "category_patterns": {
          "research": "research",
          "living-with-diabetes": "lifestyle",
          "diabetes-basics": "concepts",
          "treatment": "treatment",
          "prevention": "prevention"
        }
      },
      "pagination": {
        "type": "traditional"
      }
    }
  },
  "global_settings": {
    "default_delay": 2.0,
    "default_max_retries": 3,
    "default_timeout": 30.0,
    "default_max_pages": 5,
    "default_max_links": 50
  }
}
